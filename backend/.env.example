# Variables de entorno del Backend

PORT=3000
NODE_ENV=development

FRONTEND_URL=http://localhost:5173

# Almacenamiento de archivos (local | supabase)
STORAGE_PROVIDER=local

# Modo local: carpeta persistente y URL pública base
LOCAL_UPLOAD_DIR=uploads
PUBLIC_FILES_URL=http://localhost:3000/uploads

# Modo Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=totem-contents

# Configuracion de conexion a PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=nombre_db
PGUSER=tu_usuario
PGPASSWORD=tu_password
# Tiempo maximo para abrir conexion a PostgreSQL (ms)
PG_CONNECTION_TIMEOUT_MS=10000
# Cantidad maxima de conexiones del pool de pg
PG_POOL_MAX=5
# Cantidad maxima de conexiones del pool de Sequelize
SEQUELIZE_POOL_MAX=5

# SSL/TLS para servicios gestionados (Aiven, Neon, Render, etc.)
# Usa true cuando la base remota exige TLS.
PGSSL=false
# Alternativa para activar TLS en proveedores compatibles (ejemplo: require)
PGSSLMODE=disable
# Dejar en true para validar el certificado del servidor.
PGSSL_REJECT_UNAUTHORIZED=true
# Opcion 1 (recomendada): ruta al certificado CA descargado.
# Ejemplo: PGSSL_CA_CERT_PATH=./certs/aiven-ca.pem
PGSSL_CA_CERT_PATH=
# Opcion 2: pegar el certificado en una sola linea con \n.
PGSSL_CA_CERT=

DB_LOGGING=true

# Dashboard
# Ventana (en horas) para considerar una asignacion como proxima a expirar
DASHBOARD_ASSIGNMENT_EXPIRING_SOON_HOURS=24
# Cache del resumen del dashboard (ms)
DASHBOARD_SUMMARY_CACHE_TTL_MS=30000
# Cache (ms) para validaciones de contenidos activos con archivo no disponible
CONTENT_UNAVAILABLE_FILE_CHECK_CACHE_TTL_MS=45000
# Concurrencia de verificaciones de disponibilidad de archivo
CONTENT_FILE_AVAILABILITY_CHECK_CONCURRENCY=8

# Seguridad de sesiones (auth)
SESSION_SECRET=coloca_aqui_una_clave_larga_y_segura
SESSION_COOKIE_NAME=totem.sid
SESSION_MAX_AGE_MS=28800000
SESSION_TABLE_NAME=user_sessions
PASSWORD_SALT_ROUNDS=12

# Recuperacion de contraseña
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_TOKEN_BYTES=32
PASSWORD_RESET_FRONTEND_PATH=/admin/reset-password

# Correo SMTP (Gmail recomendado)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=tu_password_de_aplicacion
SMTP_FROM=TOTEM <tu_cuenta@gmail.com>
EMAIL_APP_NAME=TOTEM
# URL pública opcional del logo para correos (http/https)
# Ejemplo: https://tu-dominio.com/email-logo.png
EMAIL_LOGO_URL=

# Cliente totem (modo preguntas)
TOTEM_QUESTION_MODE_IDLE_TIMEOUT_SECONDS=8
TOTEM_QUESTION_MODE_REACTIVATION_COOLDOWN_SECONDS=2
TOTEM_QUESTION_SESSION_IDLE_TIMEOUT_SECONDS=20
TOTEM_QA_SEARCH_MIN_TRIGRAM_SCORE=0.18
TOTEM_QA_SEARCH_MIN_COMBINED_SCORE=0.12
TOTEM_QA_SEARCH_FTS_WEIGHT=0.72
TOTEM_QA_SEARCH_TRIGRAM_WEIGHT=0.28
TOTEM_QA_MIN_QUERY_WORD_COUNT=3
TOTEM_QA_MIN_QUERY_CHARACTER_COUNT=6
TOTEM_QA_MIN_QUERY_WORD_COVERAGE=0.5
TOTEM_QA_MIN_MATCHED_QUESTION_COVERAGE=0.6
TOTEM_QA_MIN_WORD_OVERLAP=2

# Sesiones del cliente totem
TOTEM_CLIENT_ACCESS_TOKEN_TTL_SECONDS=900
TOTEM_CLIENT_REFRESH_TOKEN_TTL_SECONDS=157680000
TOTEM_LINK_CODE_TTL_MINUTES=10
# Clima en cliente totem (Open-Meteo)
TOTEM_WEATHER_CACHE_TTL_SECONDS=600
TOTEM_WEATHER_REQUEST_TIMEOUT_MS=4500

# Invitaciones de usuarios
USER_INVITATION_TOKEN_TTL_HOURS=24
USER_INVITATION_TOKEN_BYTES=32
USER_INVITATION_FRONTEND_PATH=/set-password
